# ── Dependencies ──────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Environment files ──────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.staging
# .env.example is intentionally tracked — it is the safe reference template

# ── Build output ───────────────────────────────────────────────────
dist/
build/
out/

# ── Vite cache ─────────────────────────────────────────────────────
.vite/
*.tsbuildinfo

# ── Logs ───────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Runtime / process ──────────────────────────────────────────────
pids/
*.pid
*.seed
*.pid.lock

# ── Security & secrets ─────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
# .npmrc may contain auth tokens — keep out of source control
.npmrc

# ── OS files ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini
ehthumbs.db

# ── Editor / IDE ───────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-project
*.sublime-workspace

# Cursor IDE — local state only; rules in .cursor/rules/ should be tracked
.cursor/chat/
.cursor/scratchpad/

# ── Test & coverage output ─────────────────────────────────────────
coverage/
.nyc_output/

# ── Misc ───────────────────────────────────────────────────────────
# Temporary screenshot dumps (e.g. from browser automation)
screenshots/
*.tmp
*.temp
