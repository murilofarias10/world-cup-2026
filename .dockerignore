# Dependencies (reinstalled inside Docker)
node_modules/

# Build output (rebuilt inside Docker)
dist/

# Git
.git/
.gitignore

# Editor / OS artifacts
.vscode/
.idea/
*.DS_Store
Thumbs.db

# Environment files (never bake secrets into the image)
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# Docker files themselves
Dockerfile
.dockerignore
docker-compose*.yml

# Render config (not needed at runtime)
render.yaml
